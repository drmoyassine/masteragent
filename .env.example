# ===========================================
# Masteragent — Environment Variables
# Copy to .env and fill in real values.
# ===========================================


# ===========================================
# CORE SETTINGS
# ===========================================

# External port exposed by Docker Compose (local / non-EasyPanel deployments only).
# EasyPanel ignores this and injects its own port via docker-compose.override.yml.
PORT=8080

# CORS
CORS_ORIGINS=https://$(PRIMARY_DOMAIN)


# ===========================================
# AUTHENTICATION
# ===========================================

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_production_secure_secret_key

FRONTEND_URL=https://$(PRIMARY_DOMAIN)

# GitHub OAuth (Optional — for prompt manager GitHub storage)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://$(PRIMARY_DOMAIN)/auth/callback


# ===========================================
# DATABASE (PostgreSQL + pgvector)
# ===========================================

# Main app DB (prompt manager). Defaults to the postgres Docker service when unset.
# Change the password in production!
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/memory

# Memory system DB (same Postgres instance, same DB is fine).
MEMORY_POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/memory

# Postgres container credentials (must match DATABASE_URL / MEMORY_POSTGRES_URL above)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=memory


# ===========================================
# REDIS (Memory system cache)
# ===========================================

REDIS_URL=redis://redis:6379/0


# ===========================================
# GLiNER NER SERVICE (Optional)
# ===========================================

# Enable only if you start the gliner profile: docker compose --profile gliner up -d
ENABLE_GLINER=false
GLINER_URL=http://gliner:8002


# ===========================================
# FRONTEND BUILD
# ===========================================

# Leave empty for unified container deployments (nginx proxies /api/ to uvicorn).
# Set to https://api.yourdomain.com ONLY if running the backend as a separate service.
REACT_APP_BACKEND_URL=


# ===========================================
# n8n MCP (Claude Code cloud environment)
# ===========================================

# Used by .mcp.json to launch the community `n8n-mcp` server (npx n8n-mcp) so
# Claude Code cloud sessions can read/edit n8n workflows. Set both as secrets in
# the Claude Code environment settings (not committed to git).
# The cloud sandbox must be able to reach N8N_API_URL over the network — a
# self-hosted n8n on a private network will not be reachable from the cloud.
N8N_API_URL=https://your-n8n-instance.example.com
# Create in n8n: Settings → n8n API → Create an API key
N8N_API_KEY=your_n8n_api_key


# ===========================================
# SEED ADMINISTRATOR
# ===========================================

ADMIN_EMAIL=admin@masteragent.ai
ADMIN_PASSWORD=change_me_in_production
ADMIN_USERNAME=admin
