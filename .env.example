# ===========================================
# Masteragent — Environment Variables
# Copy to .env and fill in real values.
# ===========================================


# ===========================================
# CORE SETTINGS
# ===========================================

# External port exposed by Docker Compose (local / non-EasyPanel deployments only).
# EasyPanel ignores this and injects its own port via docker-compose.override.yml.
PORT=8080

# CORS
CORS_ORIGINS=https://$(PRIMARY_DOMAIN)


# ===========================================
# AUTHENTICATION
# ===========================================

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_production_secure_secret_key

# Separate key used for encrypting stored provider/GitHub/database credentials.
# Generate independently from JWT_SECRET_KEY: openssl rand -hex 32
DATA_ENCRYPTION_KEY=your_production_data_encryption_key
STRICT_STARTUP_VALIDATION=true
ALLOW_PUBLIC_SIGNUP=false
ENFORCE_AGENT_SCOPE=true
LEGACY_PROMPT_KEYS_GLOBAL=false
MCP_SERVICE_KEY=your_production_mcp_service_key

FRONTEND_URL=https://$(PRIMARY_DOMAIN)

# GitHub OAuth (Optional — for prompt manager GitHub storage)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://$(PRIMARY_DOMAIN)/auth/callback


# ===========================================
# DATABASE (PostgreSQL + pgvector)
# ===========================================

# Main app DB (prompt manager). Defaults to the postgres Docker service when unset.
# Change the password in production!
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/memory

# Memory system DB (same Postgres instance, same DB is fine).
MEMORY_POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/memory
DB_POOL_MIN=1
DB_POOL_MAX=20
DB_POOL_ACQUIRE_TIMEOUT_SECONDS=5

# Postgres container credentials (must match DATABASE_URL / MEMORY_POSTGRES_URL above)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=memory
# PostgreSQL container safety limits. Increase only after monitoring production usage.
POSTGRES_SHM_SIZE=512m
POSTGRES_MEM_LIMIT=4g


# ===========================================
# REDIS (Memory system cache)
# ===========================================

REDIS_URL=redis://redis:6379/0

# Maximum serialized text sent per embedding input. This stays below the
# provider token ceiling; batch isolation remains as a second safety net.
EMBEDDING_MAX_INPUT_CHARS=12000

# BullMQ job retention. These are counts, not batch sizes. Keep them bounded.
# Set to 0 only if completed/failed job records should be removed immediately.
BULL_REMOVE_ON_COMPLETE_COUNT=1000
BULL_REMOVE_ON_FAIL_COUNT=1000
# Reclaim a maintenance singleton only when its pipeline heartbeat is stale.
MAINTENANCE_LOCK_STALE_MINUTES=30

# Asynchronous discounted provider batches used by Knowledge Operations.
# Existing synchronous calibration remains available when this is false.
PROVIDER_BATCH_ENABLED=true
PROVIDER_BATCH_POLL_SECONDS=60
PROVIDER_BATCH_DELETE_FILES_AFTER_IMPORT=true
# Maximum full source records loaded into one review/submission snapshot.
# Remaining eligible records are left for a subsequent bounded submission.
# Internal preparation chunk only; this is not a user workload cap. Exhaustive
# runs are split into as many provider-safe child batches as required.
PROVIDER_BATCH_PREPARATION_CHUNK_RECORDS=10000
# Records sampled to estimate tokens/cost during mutation-free review.
PROVIDER_BATCH_PREVIEW_SAMPLE_RECORDS=250
# Maximum submitted provider child jobs per exhaustive parent operation.
PROVIDER_BATCH_MAX_CONCURRENT_JOBS=5

# Redis safety defaults. Do not enable eviction until the data classes are
# understood; noeviction makes memory pressure visible instead of silently
# dropping jobs or state.
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction

# Agent-supplied document fetch safeguards
MAX_DOCUMENT_BYTES=26214400
ALLOW_PRIVATE_DOCUMENT_URLS=false
REQUIRE_WEBHOOK_TIMESTAMP=false
LOGIN_MAX_ATTEMPTS=10


# ===========================================
# GLiNER NER SERVICE (Optional)
# ===========================================

# Enable only if you start the gliner profile: docker compose --profile gliner up -d
ENABLE_GLINER=false
GLINER_URL=http://gliner:8002


# ===========================================
# FRONTEND BUILD
# ===========================================

# Leave empty for unified container deployments (nginx proxies /api/ to uvicorn).
# Set to https://api.yourdomain.com ONLY if running the backend as a separate service.
REACT_APP_BACKEND_URL=


# ===========================================
# SEED ADMINISTRATOR
# ===========================================

ADMIN_EMAIL=admin@masteragent.ai
ADMIN_PASSWORD=change_me_in_production
ADMIN_USERNAME=admin
