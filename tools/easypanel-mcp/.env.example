# EasyPanel Configuration
EASYPANEL_URL=http://localhost:3000
EASYPANEL_API_KEY=your_api_key_here
EASYPANEL_TIMEOUT=30
EASYPANEL_VERIFY_SSL=true

# Optional Docker-level observability bridge (easypanel-api)
EASYPANEL_BRIDGE_URL=https://your-easypanel-api.example.com
EASYPANEL_API_SECRET=your_bridge_api_secret
EASYPANEL_OBSERVABILITY_TIMEOUT=45

# MCP Server Configuration
MCP_HOST=127.0.0.1
MCP_PORT=8080
MCP_LOG_LEVEL=INFO
MCP_DEBUG=false
